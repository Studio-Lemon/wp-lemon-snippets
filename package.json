{
  "name": "wp-lemon-snippets",
  "displayName": "wp-lemon-snippets",
  "icon": "wp-lemon-snippets-icon.png",
  "publisher": "StudioLemon",
  "description": "Code snippets to work with the wp-lemon WordPress theme",
  "author": "Studio Lemon <erik@studiolemon.nl>",
  "homepage": "https://studio-lemon.github.io/wp-lemon-docs/",
  "repository": {
    "type": "git",
    "url": "git@github.com:Studio-Lemon/wp-lemon-snippets.git"
  },
  "bugs": {
    "url": "https://github.com/Studio-Lemon/wp-lemon-snippets/issues"
  },
  "version": "1.4.1",
  "engines": {
    "vscode": "^1.114.0"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "Snippets",
    "Timber",
    "Twig",
    "wp-lemon",
    "studio lemon",
    "Wordpress",
    "WP"
  ],
  "scripts": {
    "deploy": "vsce publish",
    "generate-changelog": "yarn run git-cliff --unreleased --include-path=./ --prepend ./CHANGELOG.md --tag $(cat package.json | jq -r '.version')",
    "release": "PACKAGE_VERSION=$(cat package.json | grep \\\"version\\\" | head -1 | awk -F: '{ print $2 }' | sed 's/[\",]//g' | tr -d '[[:space:]]') && git tag $PACKAGE_VERSION && git push --tags && gh release create $PACKAGE_VERSION"
  },
  "contributes": {
    "snippets": [
      {
        "language": "php",
        "path": "./snippets/snippets-php-files.code-snippets"
      },
      {
        "language": "php",
        "path": "./snippets/snippets-php-snippets.code-snippets"
      },
      {
        "language": "twig",
        "path": "./snippets/snippets-twig.code-snippets"
      },
      {
        "language": "twig",
        "path": "./snippets/snippets-timber-twig.code-snippets"
      },
      {
        "language": "scss",
        "path": "./snippets/snippets-scss.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./snippets/snippets-javascript.code-snippets"
      },
      {
        "language": "html",
        "path": "./snippets/snippets-php-files.code-snippets"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.0",
    "git-cliff": "^2.11.0"
  }
}
